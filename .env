# LoKal Backend Environment Configuration
# This file configures the Django backend and Ollama connection

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,raspberrypi.local,raspilokal.com,192.168.4.1,0.0.0.0

# Ollama Settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_TIMEOUT=120

# Text-to-Speech Settings
TTS_RATE=150
TTS_VOLUME=1.0

# Vosk Speech-to-Text Model Path
# Leave commented to use default: models/vosk-model-small-en-us-0.15
# VOSK_MODEL_PATH=/home/lokal/Desktop/loKal/models/vosk-model-small-en-us-0.15
